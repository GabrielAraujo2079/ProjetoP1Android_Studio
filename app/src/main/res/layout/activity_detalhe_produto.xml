<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Detalhes do Produto"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="16dp"/>

    <ImageView
        android:id="@+id/imgDetalheProduto"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:scaleType="centerCrop"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/txtDetalheNome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/txtDetalhePreco"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="26sp"
        android:textColor="#4CAF50"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnDetalheAdicionar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Adicionar ao Carrinho"
        android:backgroundTint="#C62828"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"
        android:padding="14dp"/>

    <Button
        android:id="@+id/btnDetalheVoltar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="← Voltar"
        android:backgroundTint="#9E9E9E"
        android:textColor="#FFFFFF"
        android:padding="14dp"/>

</LinearLayout>